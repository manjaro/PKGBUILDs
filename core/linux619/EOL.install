eol() {
  echo ">>> NOTE, 6.19.14 is the last maintenance release of the 6.19 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux70 series:"
  echo "    'sudo mhwd-kernel -i linux70'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

