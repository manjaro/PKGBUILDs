eol() {
  echo ">>> NOTE, 6.10.14 is the last maintenance release of the 6.10 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux611 series:"
  echo "    'sudo mhwd-kernel -i linux611'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

