eol() {
  echo ">>> NOTE, 6.13.12 is the last maintenance release of the 6.13 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux614 series:"
  echo "    'sudo mhwd-kernel -i linux614'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

