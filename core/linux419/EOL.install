eol() {
  echo ">>> NOTE, 4.19.325 is the last maintenance release of the 4.19 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux54 series:"
  echo "    'sudo mhwd-kernel -i linux54'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

