eol() {
  echo ">>> NOTE, 6.8.12 is the last maintenance release of the 6.8 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux69 series:"
  echo "    'sudo mhwd-kernel -i linux69'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}
