eol() {
  echo ">>> NOTE, 5.18.19 is the last maintenance release of the 518 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux519 series:"
  echo "    'sudo mhwd-kernel -i linux519'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}
