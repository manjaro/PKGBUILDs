eol() {
  echo ">>> NOTE, 6.9.12 is the last maintenance release of the 6.9 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux610 series:"
  echo "    'sudo mhwd-kernel -i linux610'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

