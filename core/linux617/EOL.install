eol() {
  echo ">>> NOTE, 6.17.13 is the last maintenance release of the 6.17 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux618 series:"
  echo "    'sudo mhwd-kernel -i linux618'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}

