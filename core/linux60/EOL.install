eol() {
  echo ">>> NOTE, 6.0.19 is the last maintenance release of the 60 kernel series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux61 series:"
  echo "    'sudo mhwd-kernel -i linux61'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}
