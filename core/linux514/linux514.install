eol() {
  echo ">>> NOTE: 5.14.21 is the last maintenance release for the linux514 series."
  echo "    This kernel is now marked 'End Of Life' (EOL)."
  echo "    "
  echo "    It is recommend to switch to the newer linux515 series:"
  echo "    'sudo mhwd-kernel -i linux515'"
  echo "    "
}

post_upgrade() {
  eol
}

post_install() {
  eol
}
