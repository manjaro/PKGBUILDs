pkgname=gnome-layout-switcher
pkgver=0.8.39
pkgrel=6
pkgdesc="A simple GUI for choosing GNOME desktop layout"
arch=('any')
url="https://gitlab.manjaro.org/Chrysostomus/gnome-layout-switcher"
license=('GPL-3.0-or-later')
depends=(
  'accent-color-change'
  'addwater'
  'gdm-settings'
  'gnome-console'
  'gnome-shell'
  'gnome-shell-extension-appindicator'
  'gnome-shell-extension-arc-menu'
  'gnome-shell-extension-dash-to-dock'
  'gnome-shell-extension-dash-to-panel'
  'gnome-shell-extension-forge'
  'gnome-shell-extension-gnome-ui-tune'
  'gnome-shell-extension-gtk4-desktop-icons-ng'
  'gnome-shell-extension-space-bar'
  'gnome-tweaks'
  'gtk3'
  'pamac-gtk'
  'polkit'
  'python-click'
  'python-gobject'
)
makedepends=(
  'git'
  'python-build'
  'python-installer'
  'python-setuptools'
  'python-wheel'
)
source=("git+https://gitlab.manjaro.org/Chrysostomus/gnome-layout-switcher.git#tag=$pkgver?signed")
sha256sums=('617fd0272360d506cde1bff6f353f081379486eae244f9a5a5cd1834d478fcd9')
validpgpkeys=('688E8F82879D0E25CE541426150C200743ED46D8') # Mark Wagie <mark@manjaro.org>

prepare () {
  cd "$pkgname"
  git cherry-pick -n 6f7b5f3abe4b416dbf7305fbd5d5733bb5a86596
  git cherry-pick -n ad0a70161f75dc4f8d935874d1e279902386a5c2
  git cherry-pick -n def5a98d774fb5e8a6d4d7e5cac80d32689d768d
}

build() {
  cd "$pkgname"
  python -m build --wheel --no-isolation
}

package () {
  cd "$pkgname"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
