# Maintainer: Mark Wagie <mark at manjaro dot org>
# Contributor: dalto <dalto at fastmail.com>

pkgname=btrfs-assistant
pkgver=2.2
pkgrel=1
pkgdesc="An application for managing BTRFS subvolumes and Snapper snapshots"
arch=('x86_64' 'aarch64')
url="https://gitlab.com/btrfs-assistant/btrfs-assistant"
license=('GPL-3.0-or-later')
depends=(
  'btrfs-progs'
  'diffutils'
  'hicolor-icon-theme'
  'polkit'
  'qt6-base'
  'qt6-svg'
  'ttf-font'
  'util-linux'
)
optdepends=(
  'btrfsmaintenance'
  'qt6-wayland'
  'snapper'
)
makedepends=(
  'cmake'
  'qt6-tools'
  'vulkan-headers'
)
checkdepends=(
  'appstream'
  'desktop-file-utils'
)
backup=("etc/$pkgname.conf")
source=("$url/-/archive/$pkgver/$pkgname-$pkgver.tar.gz")
sha256sums=('cf478b7a5673a456b3aa09df2a875aae8a023511a14ef901970666b93c28ebb9')

build() {
  cmake -B build -S "$pkgname-$pkgver" \
    -DCMAKE_BUILD_TYPE='RelWithDebInfo' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -Wno-dev
  cmake --build build
}

check() {
  cd "$pkgname-$pkgver"
  appstreamcli validate --no-net "src/$pkgname.metainfo.xml" || :
  desktop-file-validate "src/$pkgname.desktop"
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
