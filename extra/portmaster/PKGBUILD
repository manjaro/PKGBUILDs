pkgname=portmaster
pkgver=2.0.0
pkgrel=2
pkgdesc="Privacy Suite and Firewall - installs the official prebuilt binaries"
arch=('x86_64')
url="https://safing.io"
license=('GPL-3.0-only')
replaces=('portmaster-stub' 'portmaster-stub-bin')
depends=(
  'cairo'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'hicolor-icon-theme'
  'libsoup3'
  'openssl'
  'pango'
  'webkit2gtk-4.1'
)
optdepends=(
  'libayatana-appindicator: for systray indicator'
  'networkmanager: recommended for better integration'
)
options=('!strip' '!emptydirs')
install="$pkgname.install"
source=("https://updates.safing.io/latest/linux_amd64/updatemgr/updatemgr"
        "$pkgname.desktop"
        "$pkgname-autostart.desktop"
        "$pkgname.service"
        "$pkgname-ui-start.sh"
        "icon-$pkgname.svg"
        "icon-$pkgname-16.png"
        "icon-$pkgname-32.png"
        "icon-$pkgname-48.png"
        "icon-$pkgname-64.png"
        "icon-$pkgname-128.png")
sha256sums=('d831dc82891c12121769b6c568ed8bdc6fad44d4da5ac6e5905c0f1a11dcc559'
            'f7b7026c4b4fe73b0401af0edec9c1458ad7d05267dbe7dfe0b7733b791c3b60'
            '0a067b241267974ab3225e904ac362eba6b0a37cc3c4ae18e30c381ad2a47076'
            'cf595fe51bbeb3242aa1cdc844e932731fdff77671d2e2a9ce8d15acffd466a6'
            '9e90c3b736bfedd89fee8bfed413187ac5996743015ab75fca359c47a71132a4'
            'a07e9af436eb1ba1292ccaf619c410b2fcd1b3c2ac430f05d0c6eba1dd6886b3'
            'f6d58c14b2cc03662d881102c332bc77ef61dd9310e994009df85d76f116d855'
            '1c7a04f8e2e5fe702d5101ea2f88a2bb32dccadb6d224a7063c72e8f23d480ca'
            'ce7d1fcb22bff821a25348c050b8b9d38a7e8123553137e70f07932ae58d6f6a'
