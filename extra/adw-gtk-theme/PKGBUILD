# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=adw-gtk-theme
pkgver=6.5
pkgrel=1
pkgdesc="The theme from libadwaita ported to GTK-3"
arch=('any')
url="https://github.com/lassekongo83/adw-gtk3"
license=('LGPL-2.1-or-later')
makedepends=(
  'dart-sass'
  'git'
  'meson'
)
conflicts=('adw-gtk3')
replaces=('adw-gtk3')
install="$pkgname.install"
source=("git+https://github.com/lassekongo83/adw-gtk3.git#tag=v$pkgver"
        'maia-accent-support.patch')
sha256sums=('0d942152e7b7f16bf9de62829e24be54f7c3866b8e6bf58068f08af7fef93bda'
            '4d82132ee8ce5bdb3af3d97d1fbcbab7d2eb722ecd5384f7542ea22438835986')

prepare() {
  cd adw-gtk3

  # accent colors
  patch -Np1 -i ../maia-accent-support.patch
}

build() {
  arch-meson adw-gtk3 build
  meson compile -C build
}

package() {
  meson install -C build --no-rebuild --destdir "$pkgdir"
}
