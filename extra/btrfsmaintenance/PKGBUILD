# Contributor: willemw <willemw12@gmail.com>

pkgname=btrfsmaintenance
pkgver=0.5.2
pkgrel=1
epoch=1
pkgdesc="Scripts for btrfs maintenance tasks"
arch=('any')
url="https://github.com/kdave/btrfsmaintenance"
license=('GPL-2.0-or-later')
depends=('bash' 'btrfs-progs' 'systemd')
backup=("etc/default/$pkgname")
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('f41f5c8a697420c282c603d96f70b25a6f4d3bf330fa0249625bce256e0cce2e')

prepare() {
  cd "$pkgname-$pkgver"
  sed -i 's|/etc/sysconfig/|/etc/default/|' "$pkgname-refresh.path"
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm644 "sysconfig.$pkgname" "$pkgdir/etc/default/$pkgname"

  install -Dm644 "$pkgname-refresh.path" -t "$pkgdir/usr/lib/systemd/system/"
  install -Dm644 ./*.service ./*.timer -t "$pkgdir/usr/lib/systemd/system/"

  install -Dm755 btrfs-*.sh "$pkgname-refresh-cron.sh" -t "$pkgdir/usr/share/$pkgname/"
  install -Dm644 "$pkgname-functions" README.md -t "$pkgdir/usr/share/$pkgname/"
}
