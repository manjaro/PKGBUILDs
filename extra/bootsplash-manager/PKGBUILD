# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=bootsplash-manager
pkgver=1.10
pkgrel=2
pkgdesc="Simple bootsplash manager"
arch=('x86_64')
url="https://github.com/parov0z/bootsplash-manager"
license=('GPL-3.0-or-later')
depends=('bootsplash-systemd' 'kauth5' 'libpamac' 'qt5-base' 'sdl2')
makedepends=('cmake' 'extra-cmake-modules' 'fmt' 'qt5-tools')
source=("$pkgname-$pkgver.tar.gz::$url/archive/$pkgver.tar.gz")
sha256sums=('5c2455770428bd87fd8bfc58bd2098d6fa110106e3107629669af431169c0789')

build() {
  cmake -B build -S "$pkgname-$pkgver" \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -Wno-dev
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
