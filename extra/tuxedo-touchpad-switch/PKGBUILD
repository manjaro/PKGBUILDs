pkgname=tuxedo-touchpad-switch
pkgver=1.1.0
pkgrel=1
pkgdesc="Toggles the touchpad and the attached disabled-LED on Uniwill/Tongfang laptops"
arch=('x86_64')
url="https://github.com/tuxedocomputers/tuxedo-touchpad-switch"
license=('GPL-3.0-or-later')
depends=(
  'glib2'
  'systemd-libs'
)
makedepends=(
  'cmake'
  'systemd'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('0816e1bbd7c45f5908fed8c845ed05820cb9c5d83f68b93a4583c15524b42dc7')

build() {
  cmake -B build -S "$pkgname-$pkgver" \
    -DCMAKE_BUILD_TYPE='None' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -Wno-dev
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
