# Maintainer: Bernhard Landauer <bernhard@manjaro.org>

pkgname=vakzination
pkgver=23.01.0
pkgrel=4
pkgdesc="Manage your health certificates like vaccination, test, and recovery certificates."
arch=('x86_64' 'aarch64')
url="https://invent.kde.org/plasma-mobile/vakzination"
license=(LGPL)
depends=('qt5-base' 'qt5-quickcontrols2' 'qt5-svg' 'kirigami2' 'ki18n5' 'kconfig5' 'prison5' 'khealthcertificate' 'kitinerary')
makedepends=('extra-cmake-modules')
source=("http://download.kde.org/stable/plasma-mobile/$pkgver/$pkgname-$pkgver.tar.xz")
md5sums=('055c96a58aeba6763d4a6abd3163071e')


prepare() {
  mkdir -p build
}

build() {
  cd build
  cmake ../$pkgname-$pkgver \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_TESTING=OFF \
    -DLIB_INSTALL_DIR=lib \
    -DKDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -DCMAKE_BUILD_TYPE=Release
  make

}

package() {
  cd build
  make DESTDIR="$pkgdir" install
}
