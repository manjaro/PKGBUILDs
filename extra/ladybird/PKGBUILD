pkgname=ladybird
pkgver=20240716
pkgrel=2
pkgdesc="Truly independent web browser"
arch=('x86_64')
url="https://ladybird.org"
license=('BSD-2-Clause')
depends=(
  'ffmpeg'
  'libgl'
  'qt6-base'
  'qt6-wayland'
  'qt6-multimedia'
  'ttf-liberation'
)
makedepends=(
  'autoconf-archive'
  'cmake'
  'curl'
  'git'
  'nasm'
  'ninja'
  'qt6-tools'
  'tar'
  'unzip'
  'zip'
)
options=(!lto !debug)
_commit=bfc9dc447f42eb9d7d0927721291d1b528b3125d  # 2024-07-16
_vcpkg_commit=f7423ee180c4b7f40d43402c2feb3859161ef625  # 2024-06-15 (Toolchain/BuildVcpkg.sh)
source=("git+https://github.com/LadybirdBrowser/ladybird#commit=${_commit}"
        "git+https://github.com/microsoft/vcpkg.git#commit=${_vcpkg_commit}"
        "${pkgname}.desktop")
b2sums=('2863c558301cfe8ceb7688cb2a32b3995601303c48986194b37df4f42dd5703258625a420fbebff56a65d1f2cf81f64f8af6eb1f69ea10685172b042f07ea5e0'
        '8af721147fcc25c8d7c7717dd950cf8db9ffa62b0e2509891885f65fb10f448a9002fb63e2be7aecbc31dd3a1f9fb3bb5694997a14c178b2709ebcaa0de50505'
        'fdd7f59391217de5d9edc9b588a2c2ea7145c7052750801a42a5f96a54b8d775c796ba58aaa84fd22f7d2b2d93e145b410e25fbe84e427aeb198b63c8cc3ee08')

build() {
  export VCPKG_ROOT="${srcdir}/vcpkg"

  cmake -B build -S "${pkgname}" --preset default \
    -DCMAKE_BUILD_TYPE='RelWithDebInfo' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -DCMAKE_INSTALL_LIBDIR="lib/${pkgname}" \
    -DCMAKE_INSTALL_LIBEXECDIR="lib/${pkgname}" \
    -DCMAKE_TOOLCHAIN_FILE="${VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake" \
    -GNinja \
    -Wno-dev
  ninja -C build
}

package() {
  DESTDIR="${pkgdir}" ninja -C build install

  cd "${pkgname}"

  for i in 48 128; do
    install -Dm644 Base/res/icons/${i}x${i}/app-browser.png \
      "${pkgdir}/usr/share/icons/hicolor/${i}x${i}/apps/${pkgname}.png"
  done

  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -Dm644 "${srcdir}/${pkgname}.desktop" -t "${pkgdir}/usr/share/applications/"

  # Remove installed tests
  rm -rf "${pkgdir}/usr/usr/"
}
