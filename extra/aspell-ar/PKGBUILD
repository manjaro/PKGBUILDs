pkgname=aspell-ar
pkgver=1.2
pkgrel=2
pkgdesc="Arabic dictionary for aspell"
arch=('any')
url="http://aspell.net/"
license=('GPL-2.0-or-later')
depends=('aspell')
source=("https://ftp.gnu.org/gnu/aspell/dict/ar/aspell6-ar-1.2-0.tar.bz2"{,.sig})
sha256sums=('041ea24a82cdd6957040e2fb84262583bf46b3a8301283a75d257a7417207cab'
            'SKIP')
validpgpkeys=('31A768B0808E4BA619B48F81B6D9D0CC38B327D7') # Kevin Atkinson <kevina@gnu.org>

build() {
  cd "aspell6-ar-${pkgver}-0"
  ./configure
  make
}

package() {
  cd "aspell6-ar-${pkgver}-0"
  make DESTDIR="$pkgdir" install
}
