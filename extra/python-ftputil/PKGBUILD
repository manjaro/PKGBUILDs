# Maintainer: Mark Wagie <mark at manjaro dot org>

# Issue tracker:
# https://todo.sr.ht/~sschwarzer/ftputil

pkgname=python-ftputil
_name=${pkgname#python-}
pkgver=5.2.0
pkgrel=1
pkgdesc="High-level FTP client library"
arch=('any')
url="https://ftputil.sschwarzer.net"
license=('BSD-3-Clause')
depends=(
  'inetutils'
  'python'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
  'python-wheel'
)
checkdepends=(
  'python-freezegun'
  'python-pytest'
)
source=("https://files.pythonhosted.org/packages/source/${_name::1}/$_name/$_name-$pkgver.tar.gz")
sha256sums=('d882ba51c5035cf8a8fb33240836075606d7629e456ac4bd0e80c0da381eef6d')

build() {
  cd "$_name-$pkgver"
  python -m build --wheel --no-isolation
}

check() {
  cd "$_name-$pkgver"

  # These tests require a real FTP server:
  ignore="${ignore-} --ignore=test/test_real_ftp.py"

  # This requires network access:
  k="${k-}${k+ and }not (TestPublicServers and test_servers)"

  # Required for TestAcceptEitherUnicodeOrBytes.test_upload, but not included in
  # the PyPI sdist. This doesn’t need to be a real Makefile; it just needs to
  # exist.
  touch Makefile

  python -m venv --clear --without-pip --system-site-packages test-env
  test-env/bin/python -m installer dist/*.whl
  test-env/bin/python -m pytest ${ignore-} -k "${k-}" -v
}

package() {
  cd "$_name-$pkgver"
  python -m installer --destdir="$pkgdir/" dist/*.whl

  install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
}
