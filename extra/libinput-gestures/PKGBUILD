# Contributor: mark.blakeney at bullet-systems dot net

pkgname=libinput-gestures
pkgver=2.80
pkgrel=1
pkgdesc="Actions gestures on your touchpad using libinput"
arch=('any')
url="https://github.com/bulletmark/libinput-gestures"
license=('GPL-3.0-or-later')
depends=(
  'hicolor-icon-theme'
  'libinput'
  'python'
)
optdepends=(
  'wmctrl: required for _internal command, as per default configuration'
  'xdotool: simulates keyboard and mouse actions for Xorg or XWayland based apps'
)
backup=("etc/$pkgname.conf")
install="$pkgname.install"
source=("$pkgname-$pkgver.tar.gz::$url/archive/$pkgver.tar.gz")
sha256sums=('9363e6d325dbd5f5d264909185a40c555ea673882d940f48156530c59babe592')

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir/" install
}
