# Maintainer: Stefano Capitani <stefanoatmanjarodotorg>

pkgname=arc-maia-icon-theme
_pkgname=arc-icon-theme
pkgver=20161122
pkgrel=4
pkgdesc="Arc icon theme Manjaro variant"
arch=('any')
url="https://github.com/horst3180/arc-icon-theme"
license=('GPL-3.0-or-later')
depends=(
  'gtk-update-icon-cache'
  'hicolor-icon-theme'
)
makedepends=(
  'inkscape'
  'libcanberra'
  'optipng'
)
optdepends=(
  'arc-themes-maia: arc-maia Gtk theme'
  'elementary-icon-theme: Secondary icon theme fallback'
#  'faba-icon-theme: Smaller version of moka with no application icons'  ## AUR
#  'moka-icon-theme: Arc icon theme was built to be used on top of Moka icon theme'  ## AUR
)
options=('!emptydirs' '!strip')
source=("${_pkgname}-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz"
        'render_icons.sh')
sha512sums=('5d0f1417358eb81994868949acefe146537d8f3cc2fd7f529f9e6ba9c264845e50962f94427bac1262a76d3ca98d05795819d7c4a6ecd3139b0b57a6e9fdfad1'
            'a7695ce03ed2545ad5a0b1c5193d38a71ca6f51a6312a2c980751402d70d3492a41392e6d97351c345639353494a379609a1f9eed30bcc6793bfa79946a6aa07')

prepare() {
  cp -Rf "${_pkgname}-$pkgver" "${_pkgname}-$pkgver-maia"
  cp -f render_icons.sh "${_pkgname}-$pkgver-maia/src/"

  cd "${_pkgname}-$pkgver-maia"

  # Remove Arc folder containing the arc icons
  rm -Rf Arc
}

build() {
  cd "${_pkgname}-$pkgver-maia"

  pushd src
  sh ./render_icons.sh
  popd

  # Arc Blue > Maia variant
  find . -type f -name '*.*' -exec sed -i "s/6ba4e7/44E2BC/g" {}  \;
  find . -type f -name '*.*' -exec sed -i "s/5294e2/16A085/g" {}  \;
  find . -type f -name '*.*' -exec sed -i "s/64a0e6/44E2BC/g" {}  \;

  # Change Theme name
  sed -i "s/Name=.*/Name=Arc-Maia/" Arc/index.theme
  sed -i "s/Comment=.*/Comment=Arc Maia Icon theme/" Arc/index.theme

  ./autogen.sh --prefix=/usr
  make
}

package() {
  cd "${_pkgname}-$pkgver-maia"
  make DESTDIR="$pkgdir" install

  cd "$pkgdir/usr/share/icons"
  mv Arc Arc-Maia
}
