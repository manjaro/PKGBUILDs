_pkgname=python3-xapp
pkgname=python-xapp
pkgver=3.0.0
pkgrel=0
pkgdesc="Python Xapp Library"
arch=('any')
url="https://github.com/linuxmint/python3-xapp"
license=('LGPL')
depends=('python' 'python-psutil')
makedepends=('meson')
source=("${_pkgname}-${pkgver}.tar.gz::${url}/archive/${pkgver}.tar.gz")
sha512sums=('2f9cb89a77cf6537e3e2d1316e7202bd1246cb1f7f6ad224f189b2b2458811c34532b02ad8facf6d6f7c0b42ed3366df69f4695091d641d87f5346b2b5b33f16')

build(){
  meson build ${_pkgname}-${pkgver} \
    --prefix=/usr
  meson compile -C build
}

package() {
  meson install -C build --destdir="${pkgdir}"

  # compile Python bytecode
  python -m compileall -d / "$pkgdir"/usr/lib
  python -O -m compileall -d / "$pkgdir"/usr/lib
}
