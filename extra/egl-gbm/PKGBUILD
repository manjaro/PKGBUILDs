# Maintainer: Mark Wagie <mark at manjaro dot org>
# Contributor: Sven-Hendrik Haase <svenstaro@archlinux.org>
pkgname=egl-gbm
pkgver=1.1.2.1
pkgrel=1.0
pkgdesc="The GBM EGL external platform library"
arch=('x86_64')
url="https://github.com/NVIDIA/egl-gbm"
license=('MIT')
depends=('eglexternalplatform' 'glibc' 'mesa' 'libdrm')
makedepends=('meson' 'git')
provides=('libnvidia-egl-gbm.so=1')
source=("git+https://github.com/NVIDIA/egl-gbm.git#tag=$pkgver"
        '15_nvidia_gbm.json')
sha256sums=('525c7c97e918d5778bbf9cf84309a9d5784c805d40fbe4409cfbcac0ddb32d76'
            'b22cd47d1a11a6c1324cff07f62f4695522ac41f945cfeb83fe484c6c56ff297')

prepare() {
  cd "$pkgname"

  # add FP16 DRM format
  # included in NVIDIA 580.126.09:
  # https://www.nvidia.com/en-us/drivers/details/261243/
  git cherry-pick -n 4e0d15931611de7b4d4cb95a52b8661a6d5a0540
}

build() {
  arch-meson "$pkgname" build
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"

  install -Dm644 15_nvidia_gbm.json -t "$pkgdir/usr/share/egl/egl_external_platform.d/"
  install -Dm644 "$pkgname/COPYING" -t "$pkgdir/usr/share/licenses/$pkgname/"
}
