# Maintainer: Mark Wagie <mark at manjaro dot org>
# Contributor: Philip Müller <philm at manjaro dot org>

pkgbase=snapd-glib
pkgname=(
  snapd-glib
  snapd-glib-docs
)
pkgver=1.72
pkgrel=1
pkgdesc="Glib library for communicating with snapd"
arch=('x86_64' 'aarch64')
url="https://github.com/canonical/snapd-glib"
license=('LGPL-2.0-only OR LGPL-3.0-only')
depends=(
  'json-glib'
  'libsoup3'
  'qt6-base'
  'qt6-declarative'
)
makedepends=(
  'gi-docgen'
  'git'
  'glib2-devel'
  'gobject-introspection'
  'meson'
  'qt6-tools'
  'vala'
)
provides=(
  'libsnapd-glib-2.so=1'
  'libsnapd-qt-2.so=1'
)
source=("git+https://github.com/canonical/snapd-glib.git#tag=$pkgver")
sha256sums=('92f168725308f85e90632266300981ad364ec4b4f71ec16b307eb2280e1f1045')
validpgpkeys=('497851B5D455C606543F2B9318EAA1890F7C882E') # Robert Ancell <robert.ancell@gmail.com>

build() {
  arch-meson "$pkgbase" build
  meson compile -C build
}

check() {
  meson test -C build --no-rebuild --print-errorlogs
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_snapd-glib() {
  meson install -C build --no-rebuild --destdir "$pkgdir"

  _pick docs "$pkgdir/usr/share/doc/$pkgname"
}

package_snapd-glib-docs() {
  arch=('any')
  pkgdesc+=" (documentation)"
  depends=()

  mv docs/* "$pkgdir"
}
