pkgname=gestures
pkgver=0.3.1
pkgrel=2
pkgdesc="Modern, minimal GUI app for libinput-gestures"
arch=('any')
url="https://gitlab.com/nokun/gestures"
license=('GPL-3.0-or-later')
depends=(
  'gtk3'
  'hicolor-icon-theme'
  'libinput-gestures'
  'python'
  'python-gobject'
)
makedepends=(
  'meson'
)
checkdepends=(
  'appstream-glib'
)
source=("https://gitlab.com/nokun/gestures/-/archive/${pkgver}/${pkgname}-${pkgver}.tar.gz")
sha256sums=('7483843e08508f6e31ebc36a2dfb3cf540a485b502736e23e40a70bfc4110890')

build() {
  arch-meson "${pkgname}-${pkgver}" build
  meson compile -C build
}

check() {
  meson test -C build --print-errorlogs || :
}

package() {
  meson install -C build --destdir "${pkgdir}"
}

