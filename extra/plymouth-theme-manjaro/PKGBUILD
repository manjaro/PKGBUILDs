pkgname=plymouth-theme-manjaro
pkgver=2.2
pkgrel=3
pkgdesc="Plymouth theme for Manjaro"
arch=('any')
url="https://gitlab.manjaro.org/artwork/themes/plymouth-manjaro"
license=('GPL-3.0-or-later')
depends=('plymouth')
makedepends=('git')
install='plymouth.install'
_commit=6cd9021070932fbcf6f9ba3f7c650e38973664cd
source=("git+https://gitlab.manjaro.org/plymouth-themes/plymouth-manjaro.git#commit=${_commit}")
sha256sums=('c67e79b70df7b2a87cf8142706660d6cc464dff1c83576959331f8e8ad911bfe')

package() {
  cd plymouth-manjaro
  install -d "$pkgdir/usr/share/plymouth/themes"
  cp -r manjaro "$pkgdir/usr/share/plymouth/themes/"
}
