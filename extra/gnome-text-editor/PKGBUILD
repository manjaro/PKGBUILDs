# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=gnome-text-editor
pkgver=42.2
pkgrel=2
pkgdesc="Simple text editor that focuses on session management"
arch=('x86_64')
url="https://gitlab.gnome.org/GNOME/gnome-text-editor"
license=('GPL3')
depends=('enchant' 'gtksourceview5' 'libadwaita' 'pcre')
makedepends=('git' 'itstool' 'meson')
checkdepends=('appstream-glib')
_commit=be4a2b2678f8f0f8f6728be8d827b4cf91f2545d # tags/42.2^0
source=("git+https://gitlab.gnome.org/GNOME/gnome-text-editor.git#commit=$_commit")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  git describe --tags | sed 's/-/+/g'
}

build() {
  arch-meson "$pkgname" build
  meson compile -C build
}

check() {
  meson test -C build --print-errorlogs || :
}

package() {
  meson install -C build --destdir "$pkgdir"
}
