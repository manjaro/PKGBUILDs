# Contributor: Marc MAURICE <dooblem[at]positon[dot]org>

pkgname=pa-applet
pkgver=20181009
pkgrel=1
pkgdesc="PulseAudio system tray applet with volume bar"
arch=('x86_64')
url="https://github.com/fernandotcl/pa-applet"
license=('BSD')
depends=('gtk3' 'libnotify' 'libpulse')
makedepends=('git')
_commit=3b4f8b3f0d0b12dcba2a78d8f2a0b06f1d377bd2  # master
source=("git+https://github.com/fernandotcl/pa-applet.git#commit=$_commit"
        "$pkgname.desktop")
sha256sums=('SKIP'
            '99db3caaf0abb403480b466d6b937c9a72c9fc17e86c07bbeaf9c973ce8da303')

pkgver() {
  cd "${srcdir}/${pkgname}"
  printf "$(git show -s --format=%cd --date=format:%Y%m%d HEAD)"
}

build() {
  cd "${srcdir}/${pkgname}"
  ./autogen.sh
  ./configure --prefix=/usr
  make
}

package() {
  cd "${srcdir}/${pkgname}"
  make DESTDIR="$pkgdir/" install

  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -Dm644 "${srcdir}/${pkgname}.desktop" -t "${pkgdir}/etc/xdg/autostart/"
}
