# Contributor: Bernhard Landauer <oberon@manjaro.org>

pkgname=masalla-icon-theme
pkgver=1.5
pkgrel=1
pkgdesc="A flat design icon theme by Hayder Majid"
arch=('any')
url="https://notabug.org/masalla-art/masalla-icon-theme"
license=('GPL-3.0-or-later')
options=('!strip')
source=("$pkgname-$pkgver-1.tar.gz::$url/archive/$pkgver-1.tar.gz")
noextract=("$pkgname-$pkgver-1.tar.gz")
sha256sums=('779aea1b2aa6395f450d46c0d34be12a487e6cd6a3ecaac93e554e3ae7342df3')

prepare() {
  mkdir -p "$pkgname-$pkgver-1"
  bsdtar xf "$pkgname-$pkgver-1.tar.gz" -C "$pkgname-$pkgver-1"
}

package() {
  cd "$pkgname-$pkgver-1"
  install -d "$pkgdir"/usr/share/icons
  cp -r "$pkgname/"{masalla,masalla-dark} "$pkgdir"/usr/share/icons
}

