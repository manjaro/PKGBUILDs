pkgname=gnome-shell-extension-dash-to-dock
pkgver=105
pkgrel=1
pkgdesc="A dock for the GNOME Shell"
arch=('any')
url="https://micheleg.github.io/dash-to-dock/"
license=('GPL-2.0-or-later')
depends=('gnome-shell')
makedepends=(
  'git'
  'sassc'
)
checkdepends=('eslint')
install='dash-to-dock.install'
source=("git+https://github.com/micheleg/dash-to-dock.git#tag=extensions.gnome.org-v$pkgver?signed")
sha256sums=('b372b62e89ce94dcba334d0e0a7f35d595114c9a469a135a76152fd41b0122e9')
validpgpkeys=('D4C501DA48EB797A081750939449C2F50996635F') # Marco Trevisan <marco@trevi.me>

build() {
  cd dash-to-dock
  make
}

check() {
  cd dash-to-dock
  make check
}

package() {
  cd dash-to-dock
  make VERSION="$pkgver" DESTDIR="$pkgdir" install
}
