pkgver=24.004.60
pkgrel=16
pkgdesc="Graphical boot splash screen"
arch=('x86_64' 'aarch64')
url="https://www.freedesktop.org/wiki/Software/Plymouth/"
license=('GPL-2.0-or-later')
