+if [ "$choice" -ge 1 ] && [ "$choice" -le 10 ]; then
   selected_color=$(echo "$colors" | cut -d' ' -f"$choice")
 
   # Map color names to escape codes using a case statement
@@ -47,6 +47,7 @@
     pink) COLOR="\e[38;5;213m" ;;
