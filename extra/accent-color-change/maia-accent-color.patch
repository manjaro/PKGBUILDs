@@ -81,9 +82,47 @@
 @define-color accent_pink #d56199;
 @define-color accent_purple #9141ac;
 @define-color accent_slate #6f8396;
+@define-color accent_maia #16a085;
 @define-color accent_bg_color @accent_$selected_color;
 EOF
 
+  # Ensure papirus-folders command exists
+  command -v papirus-folders >/dev/null || { echo "Error: papirus-folders not found."; exit 1; }
+
+  # Define Papirus folder colors
+  if [ "$selected_color" = "blue" ]; then
+    papirus_color=adwaita
+  elif [ "$selected_color" = "teal" ]; then
+    papirus_color=darkcyan
+  elif [ "$selected_color" = "orange" ]; then
+    papirus_color=deeporange
+  elif [ "$selected_color" = "purple" ]; then
+    papirus_color=magenta
+  elif [ "$selected_color" = "slate" ]; then
+    papirus_color=bluegrey
+  elif [ "$selected_color" = "maia" ]; then
+    papirus_color=teal
+  else
+    papirus_color="$selected_color"
+  fi
+
+  # Get current icon theme
+  icon_theme=$(gsettings get org.gnome.desktop.interface icon-theme | tr -d "'")
+
+  # Apply accent color to folder icons with papirus-folders if Papirus Icon theme is set
+  if [ "$icon_theme" = "Papirus-Dark" ]; then
+      papirus-folders -C "$papirus_color" --theme Papirus-Dark
+  elif [ "$icon_theme" = "Papirus-Light" ]; then
+      papirus-folders -C "$papirus_color" --theme Papirus-Light
+  else
+    echo "Set your icon theme to Papirus-Dark or Papirus-Light "
+    echo "and run the script again for matching folder colors!"
+  fi
