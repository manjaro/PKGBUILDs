# Contributor: Matti Hyttinen <mattiatmanjarodotorg>

pkgname=('manjaro-gdm-tweak')
pkgver=20190711
pkgrel=1
pkgdesc='Manjaro gdm tweak to kill the double shell'
arch=('any')
url='https://gitlab.manjaro.org/packages/extra/manjaro-gdm-tweak'
license=('GPL')
depends=('gdm')
install=$pkgname.install

pkgver() {

    date +%Y%m%d
}

package() {

	mkdir -p ${pkgdir}/etc/gdm/PostLogin
	cd ${pkgdir}/etc/gdm/PostLogin
	echo "#!/bin/sh
#Manjaro tweak to kill double shell
grep -q "^AutomaticLoginEnable=True" /etc/gdm/custom.conf || pkill -KILL -u gdm
" > default.mjo
	
}



