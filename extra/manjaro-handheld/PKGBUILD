package_manjaro-handheld() {
depends=(mangohud jq dmidecode glew glfw-x11 glxinfo)
optdepends=("os-session-select-opengamepadui: OS-Session defaulting to OpenGampadUI with InputPlumber"
            "steam: Steam support")
install=install
	mkdir -p ${pkgdir}/etc/sddm.conf.d
	echo "[General]" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "DisplayServer=wayland" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "[Autologin]" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "Relogin=true" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "Session=opengamepadui-session.desktop" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "User=gamer" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "[X11]" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "# Janky workaround for wayland sessions not stopping in sddm, kills" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "# all active sddm-helper sessions on teardown" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "DisplayStopCommand=/usr/bin/gamescope-wayland-teardown-workaround" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "# rotate screen as needed" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf
	echo "DisplayCommand=/etc/X11/Xsession.d/50rotate-screen" >> ${pkgdir}/etc/sddm.conf.d/manjaro-handheld.conf

	mkdir -p ${pkgdir}/etc/systemd/logind.conf.d
	echo "[Login]" > ${pkgdir}/etc/systemd/logind.conf.d/manjaro-handheld.conf
	echo "HandlePowerKey=suspend" >> ${pkgdir}/etc/systemd/logind.conf.d/manjaro-handheld.conf
	echo "HandleSuspendKey=suspend" >> ${pkgdir}/etc/systemd/logind.conf.d/manjaro-handheld.conf

	echo "[General]" > ${pkgdir}/etc/sddm.conf.d/virtualkbd.conf
	echo "InputMethod=qtvirtualkeyboard" >> ${pkgdir}/etc/sddm.conf.d/virtualkbd.conf

	install -Dm755 ${srcdir}/50rotate-screen -t ${pkgdir}/etc/X11/Xsession.d
	install -Dm755 ${srcdir}/com.steampowered.Logout.desktop -t ${pkgdir}/etc/skel/Desktop
	install -Dm755 ${srcdir}/com.steampowered.Logout.nonplus.desktop -t ${pkgdir}/etc/skel/Desktop
	install -Dm755 ${srcdir}/org.shadowblip.Logout.desktop -t ${pkgdir}/etc/skel/Desktop
	install -Dm644 ${srcdir}/deck-return.svg -t ${pkgdir}/usr/share/icons/hicolor/64x64/apps
	install -Dm644 ${srcdir}/org.manjaro.host.policy -t ${pkgdir}/usr/share/polkit-1/actions
	install -Dm644 ${srcdir}/org.manjaro.priv.write.policy -t ${pkgdir}/usr/share/polkit-1/actions
	install -Dm644 ${srcdir}/org.manjaro.session.select.policy -t ${pkgdir}/usr/share/polkit-1/actions
	install -Dm755 ${srcdir}/manjaro-priv-write -t ${pkgdir}/usr/bin/manjaro-polkit-helpers
	install -Dm755 ${srcdir}/manjaro-set-hostname -t ${pkgdir}/usr/bin/manjaro-polkit-helpers
	install -Dm755 ${srcdir}/manjaro-set-timezone -t ${pkgdir}/usr/bin/manjaro-polkit-helpers
	install -Dm755 ${srcdir}/gamescope-wayland-teardown-workaround -t ${pkgdir}/usr/bin
	install -Dm755 ${srcdir}/xterm.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/uxterm.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/org.kde.kuserfeedback-console.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/qvidcap.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/qv4l2.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/qdbusviewer.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/org.freedesktop.IBus.Setup.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/linguist.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/lstopo.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/htop.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/designer.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/bvnc.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/bssh.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/avahi-discover.desktop -t ${pkgdir}/usr/local/share/applications
	install -Dm755 ${srcdir}/assistant.desktop -t ${pkgdir}/usr/local/share/applications
}

package_os-session-select-steam() {
pkgdesc="OS-Session defaulting to Steam"
depends=(gamescope-session-steam-git)
provides=('os-session-select')
conflicts=(os-session-select-hhd os-session-select os-session-select-ogui)
	install -Dm755 ${srcdir}/os-session-select -t ${pkgdir}/usr/lib
	sed -i -e 's/gamescope|opengamepadui|/opengamepadui|/' \
	${pkgdir}/usr/lib/os-session-select
	sed -i -e 's/steam|/gamescope|steam|/' \
	${pkgdir}/usr/lib/os-session-select
	install -Dm755 ${srcdir}/startplasma-manjaro-oneshot -t ${pkgdir}/usr/bin
	install -Dm755 ${srcdir}/startplasma-manjaro-oneshot-wayland -t ${pkgdir}/usr/bin
	install -Dm755 ${srcdir}/plasma-manjaro-oneshot.desktop -t ${pkgdir}/usr/share/xsessions
	install -Dm755 ${srcdir}/plasma-manjaro-oneshot-wayland.desktop -t ${pkgdir}/usr/share/wayland-sessions
}

package_os-session-select-steamplus() {
pkgdesc="OS-Session defaulting to Steam-Plus with OpenGampadUI and InputPlumber"
depends=(powerstation opengamepadui opengamepadui-session-git gamescope-session-steam-plus-git)
provides=('os-session-select')
conflicts=(os-session-select-hhd os-session-select os-session-select-ogui)
	install -Dm755 ${srcdir}/os-session-select -t ${pkgdir}/usr/lib
	sed -i -e 's/gamescope|opengamepadui|/opengamepadui|/' \
	${pkgdir}/usr/lib/os-session-select
	sed -i -e 's/steam-plus|/gamescope|steam-plus|/' \
	${pkgdir}/usr/lib/os-session-select
	install -Dm755 ${srcdir}/startplasma-manjaro-oneshot -t ${pkgdir}/usr/bin
	install -Dm755 ${srcdir}/startplasma-manjaro-oneshot-wayland -t ${pkgdir}/usr/bin
	install -Dm755 ${srcdir}/plasma-manjaro-oneshot.desktop -t ${pkgdir}/usr/share/xsessions
	install -Dm755 ${srcdir}/plasma-manjaro-oneshot-wayland.desktop -t ${pkgdir}/usr/share/wayland-sessions
}

