diff --git a/src/include/Plugin.hpp b/src/include/Plugin.hpp
index 1082ae4..6e193cf 100644
--- a/src/include/Plugin.hpp
+++ b/src/include/Plugin.hpp
@@ -41,7 +41,7 @@ class DevicePlugin {
