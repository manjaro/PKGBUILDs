# Contributor: Alad <alad@archlinux.info>
# Contributor: aksr <aksr at t-com dot me>

pkgname=wmutils
pkgver=1.7
_optver=1.0
pkgrel=1
epoch=1
pkgdesc="A set of tools for X windows manipulation."
arch=('x86_64')
url="https://github.com/wmutils"
license=('ISC')
depends=('libxcb' 'xcb-util' 'xcb-util-cursor' 'xcb-util-wm')
provides=('wmutils-core' 'wmutils-opt' 'wmutils-contrib')
makedepends=('git')
source=("$pkgname-core-$pkgver.tar.gz::https://github.com/wmutils/core/archive/v$pkgver.tar.gz"
        "$pkgname-opt-$_optver.tar.gz::https://github.com/wmutils/opt/archive/v$_optver.tar.gz"
        'git+https://github.com/wmutils/contrib.git')
sha256sums=('f57da66f7da7752b1b76030b1dfdfcc0b5483f6e6d9b6ff52c6a5bb3c2af1659'
            'f30bb409bdcfa6720015dbca5356e04d4359cca3800a39948822152a94bcd055'
            'SKIP')

build() {
    pushd "core-$pkgver"
    make
    popd

    pushd "opt-$_optver"
    make
    popd

    pushd contrib/killwa
    make
    popd
}

package() {
    pushd "core-$pkgver"
    make PREFIX='/usr' DESTDIR="$pkgdir" install

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-core"
    popd

    pushd "opt-$_optver"
    make PREFIX='/usr' DESTDIR="$pkgdir" install

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-opt"
    popd

    pushd contrib/killwa
    make PREFIX='/usr' DESTDIR="$pkgdir" install

    install -Dm644 ../*.sh  -t "$pkgdir/usr/share/doc/$pkgname/examples/"
    install -Dm644 ../LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-contrib"
    popd
}
