# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=powerline-go
pkgver=1.26
pkgrel=1
pkgdesc="A Powerline like prompt for Bash, ZSH and Fish"
arch=('x86_64' 'aarch64')
url="https://github.com/justjanne/powerline-go"
license=('GPL-3.0-or-later')
depends=('glibc')
makedepends=(
  'git'
  'go'
)
optdepends=('powerline-fonts: patched fonts for powerline')
source=("git+https://github.com/justjanne/powerline-go.git#tag=v$pkgver")
sha256sums=('4b71b8ff0db981e8ad0e1f8c2358645263b27c267f1f2d0da8ca8d9aeae1c971')

prepare() {
  cd "$pkgname"
  mkdir -p build
}

build() {
  cd "$pkgname"
  export GOPATH="$srcdir/gopath"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"
  go build -v -o build .
}

package() {
  cd "$pkgname"
  install -Dm755 "build/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 README.md -t "$pkgdir/usr/share/doc/$pkgname/"
}
