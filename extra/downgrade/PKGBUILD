pkgname=downgrade
pkgver=12.0.0
pkgrel=1
pkgdesc="Bash script for downgrading one or more packages to a version in your cache or the A.L.A."
arch=('any')
url="https://archlinux-downgrade.github.io/downgrade"
license=('GPL-2.0-or-later')
depends=(
  'bash'
  'fzf'
  'pacman-contrib'
  'pacman-mirrors'
)
backup=("etc/xdg/$pkgname/$pkgname.conf")
source=("https://github.com/archlinux-downgrade/downgrade/releases/download/v$pkgver/$pkgname-$pkgver.tar.gz"
        'close-ala-in-stable.patch')
sha256sums=('ca0f768c77a7a2e4c2ee9bfbfac04995f0679923a30549c36ad9bdbe78bfd9d5'
            '97fd42ff553921fb7f90b23e4a74d9030b636a60b0a036b879fde16baf2501e0')

prepare() {
  cd "$pkgname-$pkgver"
  patch -Np1 -i "$srcdir/close-ala-in-stable.patch"
  rm -f bin/downgrade.orig  # leftover from patching, Makefile installs it if not removed
}

package() {
  cd "$pkgname-$pkgver"
  make PREFIX=/usr DESTDIR="$pkgdir" install
}
