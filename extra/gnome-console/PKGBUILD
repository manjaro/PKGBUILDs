# Maintainer: Mark Wagie <mark at manjaro dot org>
# Maintainer: Philip Müller <philm at manjaro dot org>
pkgname=gnome-console
pkgver=43.0
pkgrel=2
pkgdesc="A simple user-friendly terminal emulator for the GNOME desktop"
arch=('x86_64' 'aarch64')
url="https://gitlab.gnome.org/GNOME/console"
license=('GPL3')
depends=('libgtop' 'libadwaita' 'vte4')
makedepends=('git' 'meson')
checkdepends=('appstream-glib')
conflicts=('kgx')
replaces=('kgx')
provides=("kgx=$pkgver")
_commit=cffddb1a7bbf8ad1b1616cc026909411e218db1a # tags/43.0^0 (use gnome-43 branch)
source=("git+https://gitlab.gnome.org/GNOME/console.git#commit=$_commit")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/console"
  git describe --tags | sed 's/-/+/g'
}

build() {
  arch-meson console build -D tests=true
  meson compile -C build
}

check() {
  meson test -C build --print-errorlogs
}

package() {
  meson install -C build --destdir "$pkgdir"
}
