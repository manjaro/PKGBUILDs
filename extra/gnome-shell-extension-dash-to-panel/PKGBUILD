# Contributor: Stefano Capitani <stefanoatmanjarodotorg>
# Contributor: Balló György <ballogyor+arch at gmail dot com>

pkgname=gnome-shell-extension-dash-to-panel
pkgver=73
pkgrel=1
pkgdesc="Extension for GNOME shell to combine the dash and main panel"
arch=('any')
url="https://github.com/home-sweet-gnome/dash-to-panel"
license=('GPL-2.0-or-later')
depends=('gnome-shell')
makedepends=('git')
source=("git+https://github.com/home-sweet-gnome/dash-to-panel.git#tag=v$pkgver"
        'fix-crash-on-close.patch'
        'fix-crash-on-shutdown.patch')
sha256sums=('12f5103b481b307f92c1aed85c5fbaeebd904b0e124192e85c55f14f940827c0'
            '769621b453722543cdda0781bad73030adb6b37c5a6b773a698346708714f85f'
            '4cd889549436fdaef40095247a27a533a5021be1320e5dbe5d60e027c94630db')

prepare() {
  cd dash-to-panel

  # https://github.com/home-sweet-gnome/dash-to-panel/pull/1969
  git apply -3 ../fix-crash-on-close.patch

  # https://github.com/home-sweet-gnome/dash-to-panel/pull/2134
  git apply -3 ../fix-crash-on-shutdown.patch
}

build() {
  cd dash-to-panel
  make
}

package() {
  cd dash-to-panel
  make VERSION="$pkgver" DESTDIR="$pkgdir" install
}
