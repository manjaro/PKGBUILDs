# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=gdm-settings
pkgver=5.0+11+g8c5f90b
pkgrel=1
pkgdesc="A settings app for GNOME's Login Manager, GDM"
arch=('any')
url="https://gdm-settings.github.io"
license=('AGPL-3.0-or-later')
depends=(
  'gdm'
  'glib2-devel'
  'gtk4'
  'libadwaita'
  'polkit'
  'python-gobject'
)
makedepends=(
  'blueprint-compiler'
  'git'
  'meson'
)
_commit=8c5f90b7c58587e2967934db240061b850cd4b6b
source=("git+https://github.com/gdm-settings/gdm-settings.git#commit=${_commit}"
        'maia-color.patch'
        'https://github.com/gdm-settings/gdm-settings/pull/300.patch')
sha256sums=('cd0647a4457831d865604ecbeba0b589db31e107e9963020ee4ff6183cd9dfc4'
            'acd94585b24109ebf876c24fe42d9cafb0e97e09295472f5b1b5d6af8f503d00'
            'ec34e42dd2017f295d386d1cf5883a426443e8e006d90ba068f2cc4b909e6cf1')

pkgver() {
  cd "$pkgname"
  git describe --tags --abbrev=7 | sed 's/^v//;s/-/+/g'
}

prepare() {
  cd "$pkgname"

  # Add VRR Support
  # https://github.com/gdm-settings/gdm-settings/issues/283
  patch -Np1 -i ../300.patch

  # Add Maia accent color
  patch -Np1 -i ../maia-color.patch
}

build() {
  arch-meson "$pkgname" build --buildtype=release
  meson compile -C build
}

check() {
  meson test -C build --no-rebuild --print-errorlogs
}

package() {
  meson install -C build --no-rebuild --destdir="$pkgdir"
}
