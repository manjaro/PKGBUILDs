# Maintainer: Mark Wagie <mark at manjaro dot org>
# Contributor: Andrey Alekseev <andrey.android7890@gmail.com>

pkgname=bootsplash-theme-manjaro-glitch
_pkgname=bootsplash-manjaro-glitch
pkgver=1.0
pkgrel=2
pkgdesc="Simple Manjaro Bootsplash with cool glitch effect"
arch=('x86_64')
url="https://github.com/parov0z/bootsplash-theme-manjaro-glitch"
license=('LicenseRef-unknown')
makedepends=('git' 'imagemagick')
optdepends=('bootsplash-systemd: for bootsplash functionality')
source=("git+https://github.com/parov0z/bootsplash-theme-manjaro-glitch.git#tag=v$pkgver")
sha256sums=('a06554a16e5a91653997f06c8d2d99a2826545a1463dd147964ea85a7211296e')

build() {
  cd "$pkgname"
  ./"${_pkgname}.sh"
}

package() {
  cd "$pkgname"
  install -Dm644 "${_pkgname}" \
    "$pkgdir/usr/lib/firmware/bootsplash-themes/manjaro-glitch/bootsplash"
  install -Dm644 "${_pkgname}.initcpio_install" \
    "$pkgdir/usr/lib/initcpio/install/${_pkgname}"
}
