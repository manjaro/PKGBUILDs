# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=plasma6-applets-supergfxctl
pkgver=2.1.1
pkgrel=3
pkgdesc="KDE Plasma plasmoid for supergfxctl"
arch=('x86_64')
url="https://gitlab.com/Jhyub/supergfxctl-plasmoid"
license=('MPL-2.0')
depends=(
  'hicolor-icon-theme'
  'kconfig'
  'kcoreaddons'
  'ki18n'
  'libplasma'
  'qt6-base'
  'qt6-declarative'
  'solid'
  'supergfxctl'
)
makedepends=(
  'cmake'
  'extra-cmake-modules'
)
checkdepends=('appstream')
conflicts=('plasma5-applets-supergfxctl')
replaces=('plasma5-applets-supergfxctl')
source=("$url/-/archive/v$pkgver/supergfxctl-plasmoid-v$pkgver.tar.gz")
sha256sums=('eb7b9e28bc3786abeaea9f4ae565b701033b0a58ded0d9f8e28f7ea2063b00fa')

build() {
  cmake -B build -S "supergfxctl-plasmoid-v$pkgver" \
    -DCMAKE_BUILD_TYPE='None' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -Wno-dev
  cmake --build build
}

check() {
  ctest --test-dir build --output-on-failure
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
