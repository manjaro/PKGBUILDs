# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=ptyxis
pkgver=48.1
pkgrel=1
pkgdesc="A terminal for GNOME with first-class support for containers."
arch=('x86_64' 'aarch64')
url="https://gitlab.gnome.org/chergert/ptyxis"
license=('GPL-3.0-or-later')
depends=(
 'json-glib'
 'libadwaita'
 'libportal-gtk4'
 'vte4>=0.78.0'
)
makedepends=(
  'git'
  'glib2-devel'
  'meson'
)
source=("git+https://gitlab.gnome.org/chergert/ptyxis#tag=$pkgver")
sha256sums=('bfb4da8460e5b242cf8b6cef9a7284a71f5656761bad9d9de674ad867d01a9b8')

build() {
  arch-meson "$pkgname" build -Dgeneric=terminal
  meson compile -C build
}

check() {
  meson test -C build --no-rebuild --print-errorlogs
}

package() {
  meson install -C build --no-rebuild --destdir "$pkgdir"
}
