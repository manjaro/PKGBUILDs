# Maintainer: Philip Müller <philm[at]manjaro[dot]org>
# Maintainer: Bernhard Landauer <bernhard@manjaro.org>

_linuxprefix=linux54

_module=nvidiabl
pkgname="${_linuxprefix}-${_module}"
pkgver=0.88
pkgrel=345
pkgdesc="Driver to adjust display backlight on modern mobile NVidia graphics adapters."
arch=('x86_64')
url="https://github.com/guillaumezin/nvidiabl"
license=('GPL')
groups=("${_linuxprefix}-extramodules")
depends=("${_linuxprefix}")
makedepends=('git' "${_linuxprefix}-headers")
provides=("${_module}")
_commit=7dbb99e6782455c2794486fd3acf5c15b3256b1a  # master
source=("git+https://github.com/guillaumezin/nvidiabl#commit=${_commit}"
        "${_module}-master.patch"
        "kernel-4.8.patch")
sha256sums=('SKIP'
            'dd46e1f5ffaae6eae43b45e254d938e85377d4abe84617232c8379e609af3c39'
            '689b15dc41867d4495eaacba47735669cdfd3b5361a60e046747fd52ef46b878')

prepare() {
  cd "${_module}"
  patch -Np1 -i ../"${_module}-master.patch"
  patch -Np1 -i ../kernel-4.8.patch
}

build() {
  _kernver="$(cat /usr/src/${_linuxprefix}/version)"

  cd "${_module}"
  make KVER="${_kernver}"
}

package() {
  _kernver="$(cat /usr/src/${_linuxprefix}/version)"

  cd "${_module}"
  MODPATH="${pkgdir}/usr/lib/modules/${_kernver}/extramodules/"
  install -d $MODPATH
  install -m 644 -c *.ko $MODPATH
  find "$pkgdir" -name "*.ko" -exec xz {} +
}
