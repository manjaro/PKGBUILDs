# Maintainer: linux-aarhus <fh at manjaro . org>

pkgname='manjaro-get-iso'
pkgver=0.20
pkgrel=1
pkgdesc='A tool to download Manjaro ISO'
arch=('any')
url='https://gitlab.manjaro.org/fhdk/manjaro-get-iso'
license=('MIT')
depends=('python-requests' '7zip')
source=("https://gitlab.manjaro.org/applications/manjaro-get-iso/-/archive/v${pkgver}/${pkgname}-v${pkgver}.tar.gz")

package() {
    cd "${pkgname}-v${pkgver}"
    install -Dm755 get-iso -t "$pkgdir/usr/bin"
    install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

sha256sums=('323ce2ff7164e782e2fe1c0e4b2eed8fda536d4d90df59bb85b6c7810bc84426')
