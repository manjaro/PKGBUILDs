# Maintainer: Philip Mueller <philm@manjaro.org>

pkgname=plasma-setup
pkgver=6.6.5
pkgrel=1
pkgdesc='KDE Plasma first run setup tool'
arch=('x86_64')
url="https://kde.org/plasma-desktop"
license=('GPL-2.0-or-later')
depends=(
  'kauth'
  'kconfig'
  'kcoreaddons'
  'ki18n'
  'kpackage'
  'libkscreen'
  'plasma-desktop'
  'plasma-workspace'
  'qt6-base'
  'qt6-declarative'
)
makedepends=(
  'cmake'
  'extra-cmake-modules'
  'git'
)
source=("git+https://invent.kde.org/plasma/plasma-setup.git#tag=v$pkgver"
        '0000-kill-plymouth.patch')
sha256sums=('57bb9069d6ac8b0782bb3f7ba0acc6b60e892b6e8fe9bf2790e7fe7bdd333db1'
            'a9fe89958f319f8930254d3d7d85f9c95fae22d980c7595c8951d87941ead022')

_backports=(
)

_reverts=(
)

prepare() {

  # return if not a git repository
  if ! git status >/dev/null 2>&1; then
    return
  fi

  local _c _l
  for _c in "${_backports[@]}"; do
    if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
    git --no-pager log --oneline "${_l}" "${_c}"
    git cherry-pick --mainline 1 --no-commit "${_c}"
  done
  for _c in "${_reverts[@]}"; do
    if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
    git --no-pager log --oneline "${_l}" "${_c}"
    git revert --mainline 1 --no-commit "${_c}"
  done

  cd "$pkgname"
  patch -Np1 -i ../0000-kill-plymouth.patch
}

build() {
  cmake -B build -S "$pkgname" \
    -DCMAKE_BUILD_TYPE='RelWithDebInfo' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DBUILD_TESTING='OFF' \
    -Wno-dev
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
