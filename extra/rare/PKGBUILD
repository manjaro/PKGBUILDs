# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=rare
pkgver=1.12.0
pkgrel=3
pkgdesc="An open source alternative for Epic Games Launcher, using Legendary."
arch=('any')
url="https://raredevs.github.io/Rare"
license=('GPL-3.0-or-later')
depends=(
  'legendary-rare'
  'pyside6'
  'python-orjson'
  'python-qtawesome'
  'python-requests'
  'python-vdf'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
  'python-setuptools-scm'
  'python-wheel'
)
optdepends=(
  'python-pypresence: Discord RPC integration'
  'python-pywebview: embedded browser for logging in'
  'wine: run Windows games'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/RareDevs/Rare/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('75f97dc4ec936869736e42f01c7464b2965272a7adcc932d1b66d6c0a71b5464')

build() {
  cd "Rare-$pkgver"
  export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "Rare-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 "misc/$pkgname.desktop" -t "$pkgdir/usr/share/applications/"
  install -Dm644 "$pkgname/resources/images/Rare.png" \
    "$pkgdir/usr/share/pixmaps/$pkgname.png"
}
