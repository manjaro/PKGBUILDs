# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=asusctltray
pkgver=r28.c8ef0ba
pkgrel=1
pkgdesc="Simple tray profile switcher for asusctl"
arch=('any')
url="https://github.com/Baldomo/asusctltray"
license=('MIT')
depends=(
  'asusctl'
  'gtk3'
  'libappindicator-gtk3'
  'polkit'
  'python-dbus'
  'python-gobject'
  'supergfxctl'
)
makedepends=('desktop-file-utils' 'git')
_commit=c8ef0ba265fedbcd62bf6a2910a506e8c4032714  # branch/master
source=("git+https://github.com/Baldomo/asusctltray.git#commit=${_commit}")
sha256sums=('0e009d49ca7ba2bd5e962b52078ed521b6d68277625a730e09d30798233bc775')

pkgver() {
  cd "$pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$pkgname"
  desktop-file-edit --set-icon="$pkgname" "$pkgname.desktop"
}

package() {
  cd "$pkgname"
  install -Dm755 "$pkgname" -t "$pkgdir/usr/bin/"
  install -Dm644 "$pkgname.svg" -t "$pkgdir/usr/share/icons/hicolor/scalable/apps/"
  install -Dm644 "$pkgname.desktop" -t "$pkgdir/usr/share/applications/"
  install -Dm644 LICENSE.txt -t "$pkgdir/usr/share/licenses/$pkgname/"
}
