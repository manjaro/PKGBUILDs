# Maintainer: fhdk <fh at manjaro org>

pkgname=manjaro-openbox-flatred-theme
_gitname=nixbox-theme
pkgver=0.3
pkgrel=1
arch=('any')
license=('MIT')
makedepends=('git')
requires=('kvantum')
url="https://codeberg.org/fhdk/nixbox-theme"
pkgdesc="Openbox Theme"
source=("git+$url.git#branch=main")
provides=('manjaro-openbox-flatred-theme')
sha256sums=('SKIP')

package() {
    install -d -m755 $pkgdir/usr/share/themes/NixBoxFlatRed
    install -d -m755 $pkgdir/usr/share/Kvantum/KvNixBoxFlatRed
    cd $srcdir/$_gitname
    cp -R gtk/NixBoxFlatRed $pkgdir/usr/share/themes
    cp -R kvantum/KvNixBoxFlatRed $pkgdir/usr/share/Kvantum
}
