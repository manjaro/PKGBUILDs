# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=gnome-shell-extension-custom-accent-colors
_uuid=custom-accent-colors@demiskp
pkgver=11
pkgrel=2
pkgdesc="Set a custom accent color for GTK4/GTK3 apps and GNOME Shell"
arch=('any')
url="https://github.com/demiskp/custom-accent-colors"
license=('GPL-3.0-or-later')
depends=('adw-gtk-theme' 'gnome-shell')
makedepends=('git')
source=("git+https://github.com/demiskp/custom-accent-colors.git#tag=v$pkgver"
        'gnome-shell.css'
        'gtk.css'
        'toggle-on_maia.svg')
sha256sums=('e8d739a4d05a03a9690daf1549174c931a7f4b85866a0496e92620d813e95290'
            'dfe9817b9bab3c83f6501b8f1d5e3ccf00a741790055c3aa65936bf44f5278ee'
            'b9e4f7dffc517934c6b5d576850cca91a72b135a7d57e2154d6ecd312f6da0b7'
            'eb0eda198d3054758b4d09f7a415e06f7c13af704ac294758c0b0bcc52a981e6')

prepare() {
  cd custom-accent-colors

  # Add Maia color option
  sed -i "/'Default', 'default'/a \ \ \ \ \ \ \ \ listModel.append(new CustomAccentColors('Maia', 'maia'));" "${_uuid}/prefs.js"
}

package() {
  cd custom-accent-colors
  install -d "$pkgdir/usr/share/gnome-shell/extensions"
  cp -r "${_uuid}" "$pkgdir/usr/share/gnome-shell/extensions/"

  install -Dm644 "$srcdir/gtk.css" -t \
    "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/resources/maia/"
  install -Dm644 "$srcdir/toggle-on_maia.svg" \
    "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/resources/maia/gnome-shell/46/toggle-on.svg"
  install -Dm644 "$srcdir/gnome-shell.css" \
    "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/resources/maia/gnome-shell/46/gnome-shell.css"

  install -Dm644 "${_uuid}/schemas/org.gnome.shell.extensions.custom-accent-colors.gschema.xml" -t \
    "$pkgdir/usr/share/glib-2.0/schemas/"
  rm -rf "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/schemas"
}
