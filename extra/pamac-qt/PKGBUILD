# Maintainer: Artyom Grinyov (LordTermor)

pkgbase=pamac-qt
pkgname=('pamac-qt')
_pkgver=0.3.2
pkgver=0.3.2
pkgrel=2
_commit=056a862830fffb840457401bb3e60fb46848ac7b
_ver="$pkgver-g${_commit:0:7}"
pkgdesc="A Qt5 frontend for libalpm - prerelease version"
arch=('i686' 'x86_64')
url="https://gitlab.manjaro.org/applications/pamac-qt"
license=('GPL3')
depends=('pamac-common>=9.5.0' 'pamac-common<9.6.0' 'qt5-base>=5.15.0' 'qt5-quickcontrols2' 'qt5-quickcontrols' 'qt5-graphicaleffects' 'qqc2-desktop-style' 'breeze-icons')
makedepends=('git' 'cmake')
options=(!emptydirs)

source=("$pkgname-$pkgver-$pkgrel.tar.gz::$url/-/archive/$_commit/$pkgname-$_commit.tar.gz")
sha256sums=('c305d5c934329bfeb8b90f739b3e28703f93432027e0554216081f7dec116c72')

prepare() {
  mkdir -p build
}

build() {
  cd build
  cmake -DVERSION="$_ver" -DCMAKE_INSTALL_PREFIX="/usr" ../$pkgname-$_commit
  make
}

package() {
  cd build
  make DESTDIR="${pkgdir}" install
}
