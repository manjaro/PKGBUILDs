# Contributor: FadeMind <fademind@gmail.com>

pkgname=('manjaro-wallpapers-18.0' 'illyria-wallpaper')
pkgbase=manjaro-wallpapers-18.0
pkgver=1.4
pkgrel=4
pkgdesc="Official Wallpapers for the Manjarolinux 18.x release"
arch=('any')
url="https://gitlab.manjaro.org/artwork/wallpapers/manjaro-wallpapers-18.0"
license=('GPL-3.0-or-later')
options=('!strip')
source=("$url/-/archive/$pkgver/$pkgbase-$pkgver.tar.gz")
sha256sums=('ca0427e47d96ae6de5532b88b4c55a6212e3cdc94f38e7092962bd515dc1c30e')

package_manjaro-wallpapers-18.0() {
  depends=('illyria-wallpaper')

  cd "$pkgbase-$pkgver"
  make DESTDIR="$pkgdir" install

  rm -v "$pkgdir/usr/share/backgrounds/$pkgbase"/illyria-default{,-lockscreen}.jpg

  install -d "$pkgdir"/usr/share/backgrounds/xfce
  for i in $(ls "$pkgdir"/usr/share/backgrounds/$pkgbase); do
    ln -sv "/usr/share/backgrounds/$pkgbase/${i}" "$pkgdir/usr/share/backgrounds/xfce/${i}"
  done
}

package_illyria-wallpaper() {
  cd "$pkgbase-$pkgver"
  install -Dm644 illyria-default.jpg "$pkgdir"/usr/share/backgrounds/illyria-default.jpg
  install -m644 illyria-default-lockscreen.jpg "$pkgdir"/usr/share/backgrounds/illyria-default-lockscreen.jpg
}
