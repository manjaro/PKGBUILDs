# Maintainer: Mark Wagie <mark at manjaro dot org>

pkgname=nautilus-open-any-terminal
pkgver=0.8.1
pkgrel=1
pkgdesc="Nautilus extension which adds a context entry for opening other terminal emulators"
arch=('any')
url="https://github.com/Stunkymonkey/nautilus-open-any-terminal"
license=('GPL-3.0-or-later')
depends=('nautilus-python')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz"
        "com.github.stunkymonkey.$pkgname.gschema.override")
sha256sums=('09a07fad2908e66063d19dd428e70adaf6147d9918e7d52503ff8e74b54f79f1'
            '44cf07db726144563e7c98522899770c5b5c9cf6b1302188f84db18e6aa20d42')

build() {
  cd "$pkgname-$pkgver"
  make build
}

package() {
  cd "$pkgname-$pkgver"
  make PREFIX='/usr' DESTDIR="$pkgdir" install-nautilus

  # Set default terminal to GNOME Console
  install -Dm644 "$srcdir/com.github.stunkymonkey.$pkgname.gschema.override" -t \
    "$pkgdir/usr/share/glib-2.0/schemas/"
}
