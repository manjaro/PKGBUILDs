# See https://support.codeweavers.com/missing-libraries
# and /opt/cxoffice/share/crossover/data/cxfixes.xml for dependencies

pkgname=crossover
pkgver=26.1.0
pkgrel=1
_pkgdebrel=1
pkgdesc="Run Windows Programs on Linux"
arch=('x86_64')
url="https://www.codeweavers.com/crossover"
license=('LicenseRef-custom')
depends=(
    'desktop-file-utils'
    'gtk3'
    'gzip'
    'python'
    'python-cairo'
    'python-gobject'
    'python-pyxdg'
    'lib32-alsa-lib'
    'lib32-glibc>=2.11'
    'lib32-freetype2'
    'lib32-libglvnd'
    'lib32-libice'
    'lib32-libpng'
    'lib32-libpulse'
    'lib32-libsm'
    'lib32-libx11'
    'lib32-libxext'
    'lib32-libxrandr'
    'lib32-libxrender'
    'lib32-mesa'
    'lib32-zlib'
    'libpulse'
    'libunwind'
    'libxcrypt-compat'
    'openssl'
    'perl'
    'vte3'
)
optdepends=(
    "lib32-fontconfig: Lets Windows applications find and use the system's TrueType fonts. This is strongly recommended for office-type applications"
    'lib32-gcc-libs: Needed to unpack installers in the .7z format'
    'lib32-glu: May be needed by some games or CAD applications'
    'lib32-gmp: Needed by some Windows applications (Quicken, Outlook, Diablo III, and many more) to perform encryption or check online certificates'
    'lib32-gnutls: Needed by some Windows applications (Quicken, Outlook, Diablo III, and many more) to perform encryption or check online certificates'
#    'lib32-gsm: Lets Windows applications use the GSM codec (msgsm32.acm) for audio compression and decompression'  ## AUR
#    'lib32-gst-libav: May be needed by some games and multimedia applications to play audio and/or video content'  ## AUR
#    'lib32-gst-plugins-bad: May be needed by some games and multimedia applications to play audio and/or video content'  ## AUR
#    'lib32-gst-plugins-base: Needed by some games and multimedia applications to play audio and/or video content'  ## AUR
#    'lib32-gst-plugins-good: May be needed by some games and multimedia applications to play audio and/or video content'  ## AUR
#    'lib32-gst-plugins-ugly: May be needed by some games and multimedia applications to play audio and/or video content'  ## AUR
#    'lib32-gstreamer: Needed by some games and multimedia applications to play audio and/or video content'  ## AUR
    'lib32-krb5: Lets Windows applications use the Kerberos authentication protocol'
    'lib32-lcms2: Provides color profile information to Windows applications. This is particularly useful if you have color-calibrated your screen but some applications need it even if you have not done so'
    'lib32-libcups: Needed to access printers managed by CUPS. Without it printing is most likely impossible so this is strongly recommended for office-type applications'
    'lib32-libdbus: Lets Windows applications automatically detect the insertion of media such as CD-ROMs and USB flash drives. Without it the corresponding Windows drive letters must be created manually'
    'lib32-libldap: Lets Windows applications access LDAP servers'
    'lib32-libtiff: Needed by some Windows applications that manipulate TIFF images'
    'lib32-libusb: Provide Windows applications with access for controlling data transfer to and from USB devices'
    'lib32-libxcomposite: Needed for Windows applications that display 3D graphics in a window. This includes most CAD-like applications and some games'
    'lib32-libxcursor: Lets Windows applications use color mouse pointers. This is mostly useful for some games'
    'lib32-libxfixes: Provides better copy/paste support from X to Windows applications'
    "lib32-libxi: Provides support for joysticks and graphics tablets. If you don't have such a device you don't need it"
    'lib32-libxinerama: If your computer has multiple display screens, the Xinerama library lets Windows applications take advantage of them'
    'lib32-libxml2: Lets Windows applications read and write XML files'
    'lib32-libxslt: Lets Windows applications perform queries and transformations on XML files'
    'lib32-libxxf86vm: Lets Windows games perform gamma correction on the screen to adjust the brightness'
    'lib32-mpg123: May be needed by some games and multimedia applications to play audio content'
    "lib32-ocl-icd: Some Windows applications use OpenCL to leverage the graphics card's GPU to speed up parallel computing tasks"
    'lib32-openal: Some Windows applications use the OpenAL library to produce three-dimensional positional audio'
    'lib32-openssl: Provides support for secure Internet communication'
    'lib32-pcsclite: Provides access to smart cards'
    'lib32-systemd: Provides access to the udev Linux device manager and lets Windows applications detect HID devices such as game controllers'
#    'lib32-unixodbc: Lets Windows applications use the ODBC API to access databases'  ## AUR
    'lib32-v4l-utils: Lets Windows applications access video capture devices such as webcams and TV tuners'
    'lib32-vulkan-icd-loader: Needed for games which use the Vulkan graphics API; for D3D12 applications; and for the DXVK layer for D3D11'
    'lib32-wayland: Can be used to display the graphical user interface of Windows applications directly through Wayland. It is strongly recommended to use the X Window System instead (libX11)'
    'libxcrypt-compat: Needed for NTLM authentication'
    'polkit: May be needed to run commands as root'
    'unzip: Required to install Guild Wars, automatic installer extraction'
)
install="${pkgname}.install"
source=("https://media.codeweavers.com/pub/${pkgname}/cxlinux/demo/${pkgname}_${pkgver}-${_pkgdebrel}.deb")
sha256sums=('7b8cbb29ed7eaf2c134645aea812aaedac50bb7f0da66634fde2cda532a4c84e')

package() {
    bsdtar Jxf data.tar.xz -C "${pkgdir}"

    sed -e 's!;;"MenuRoot" = ""!"MenuRoot" = "Windows Games"!' \
        -e 's!;;"MenuStrip" = ""!"MenuStrip" = "1"!' \
        -i "${pkgdir}/opt/cxoffice/share/${pkgname}/bottle_data/cxbottle.conf"

    install -d "${pkgdir}/usr/bin"
    ln -s "/opt/cxoffice/bin/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
    ln -s /opt/cxoffice/bin/cxsetup "${pkgdir}/usr/bin/cxsetup"

    install -d "${pkgdir}/etc/profile.d"
    echo '[ -d /opt/cxoffice/bin ] && export PATH="${PATH}:/opt/cxoffice/bin"' > "${pkgdir}/etc/profile.d/cxoffice.sh"
    echo '[ -d /opt/cxoffice/bin ] && setenv PATH ${PATH}:/opt/cxoffice/bin' > "${pkgdir}/etc/profile.d/cxoffice.csh"
    chmod 755 "${pkgdir}/etc/profile.d/cxoffice.sh" "${pkgdir}/etc/profile.d/cxoffice.csh"

    # Fix Auto update error
    install -m 644 -D "${pkgdir}/opt/cxoffice/share/${pkgname}/data/cxoffice.conf" "${pkgdir}/opt/cxoffice/etc/cxoffice.conf"
    sed -e 's!;;"PrivateShortcutDirs" = ""!"PrivateShortcutDirs" = "${HOME}/bin:${CX_ROOT}/bin"!' \
        -e 's!;;"PrivateLinuxNSPluginDirs" = ""!"PrivateLinuxNSPluginDirs" = "${MOZ_PLUGIN_PATH}"!' \
        -e 's!;;"PrivateLinux64NSPluginDirs" = ""!"PrivateLinux64NSPluginDirs" = "${MOZ_PLUGIN_PATH}"!' \
        -e 's!;;"ProductPackage" = ""!"ProductPackage" = "Converted from .deb to pacman."!' \
        -i "${pkgdir}/opt/cxoffice/etc/cxoffice.conf"

    # place license in correct directory
    install -d "${pkgdir}/usr/share/licenses/${pkgname}/"
    cat "${pkgdir}/usr/share/doc/${pkgname}/license.txt.gz" | gzip -d > "${pkgdir}/usr/share/licenses/${pkgname}/license.txt"
    ln -s "/usr/share/doc/${pkgname}/copyright" "${pkgdir}/usr/share/licenses/${pkgname}/"

    # Remove Lintian
    rm -rf "${pkgdir}/usr/share/lintian/"
}
