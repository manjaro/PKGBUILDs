pkgname=lib32-nss-mdns
_pkgname=${pkgname#lib32-}
pkgver=0.15.1
pkgrel=1
pkgdesc="glibc plugin providing host name resolution via mDNS (32-bit)"
arch=('x86_64')
url="https://0pointer.de/lennart/projects/nss-mdns/"
license=('LGPL-2.1-or-later')
depends=('lib32-glibc')
makedepends=('lib32-gcc-libs')
source=("https://github.com/lathiat/nss-mdns/releases/download/v${pkgver}/${_pkgname}-${pkgver}.tar.gz")
sha256sums=('ddf71453d7a7cdc5921fe53ef387b24fd0c3c49f4dcf94a2a437498596761a21')

build() {
    export CC="gcc -m32"
    export CXX="g++ -m32"
    export PKG_CONFIG_PATH="/usr/lib32/pkgconfig"

    cd ${_pkgname}-${pkgver}
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --libdir=/usr/lib32 \
        --disable-lynx
    make
}

package() {
    cd ${_pkgname}-${pkgver}
    make DESTDIR="${pkgdir}" install
}
