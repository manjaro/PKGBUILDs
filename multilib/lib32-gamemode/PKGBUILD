# Maintainer: Mark Wagie <mark@manjaro.org>
# Contributor: Ysblokje <ysblokje at gmail dot com>
pkgname=lib32-gamemode
_pkgname=${pkgname#lib32-}
pkgver=1.6
pkgrel=2
pkgdesc="Optimise Linux system performance on demand"
arch=('x86_64')
url="https://github.com/FeralInteractive/gamemode"
license=('BSD')
depends=('gamemode' 'lib32-glibc' 'lib32-dbus')
makedepends=('meson' 'lib32-systemd')
source=("$url/releases/download/$pkgver/$_pkgname-$pkgver.tar.xz")
sha256sums=('ede17eb042c1c87f7b35bfe96a00560afaea086f685d25bb3964d794b0af9c80')

build() {
	export CFLAGS=-m32
	export CXXFLAGS=-m32
	export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'

	arch-meson "$_pkgname-$pkgver" build  \
		--libdir lib32 \
		-Dwith-sd-bus-provider=no-daemon \
		-Dwith-examples=false \
		-Dwith-util=false
	meson compile -C build
}

package() {
	DESTDIR="$pkgdir" meson install -C build

	rm -rf "$pkgdir/usr/include"

	cd "$_pkgname-$pkgver"
	install -Dm644 LICENSE.txt -t "$pkgdir/usr/share/licenses/$pkgname"
}
